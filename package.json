{
  "name": "nuxt-app",
  "type": "module",
  "private": true,
  "packageManager": "yarn@4.17.0",
  "scripts": {
    "build": "nuxt build --preset=cloudflare_pages",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "yarn build && wrangler pages dev",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:reset:local": "wrangler d1 execute --local juoksut-products --file ./d1/schema.sql && wrangler d1 execute --local juoksut-products --file ./d1/seed.sql",
    "db:seed:local": "wrangler d1 execute --local juoksut-products --file ./d1/seed.sql",
    "dev:fresh": "yarn db:reset:local && nuxt dev"
  },
  "dependencies": {
    "@nuxt/image": "^2",
    "pinia-plugin-persistedstate": "^4.2.0",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@nuxt/eslint": "^1.16.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@pinia/nuxt": "^0.11.3",
    "eslint": "^10.5.0",
    "eslint-plugin-format": "^2.0.1",
    "nitro-cloudflare-dev": "^0.2.2",
    "nuxt": "^4",
    "pinia": "^3.0.1",
    "typescript": "^5.8.2",
    "vitest": "^4.1.9",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "wrangler": "^4.103.0"
  },
  "resolutions": {
    "tailwindcss": "3.4.17"
  }
}
